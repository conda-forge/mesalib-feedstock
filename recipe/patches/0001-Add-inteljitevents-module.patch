From af08b1273586fb08e2005637729fdef68775fa40 Mon Sep 17 00:00:00 2001
From: Jarrett Johnson <jarrett.johnson@schrodinger.com>
Date: Mon, 18 Aug 2025 23:23:25 -0400
Subject: [PATCH] Add inteljitevents module

# LLVM from conda-forge comes with inteljitevents. The LLVMConfig
# header will define IntelJITEvents headers while building mesa
# so this module should be included in the build.
---
 meson.build | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/meson.build b/meson.build
index cc901ec629e..88e32893d51 100644
--- a/meson.build
+++ b/meson.build
@@ -1805,7 +1805,7 @@ if dep_libudev.found()
   pre_args += '-DHAVE_LIBUDEV'
 endif
 
-llvm_modules = ['bitwriter', 'engine', 'mcdisassembler', 'mcjit', 'core', 'executionengine', 'scalaropts', 'transformutils', 'instcombine']
+llvm_modules = ['bitwriter', 'engine', 'mcdisassembler', 'mcjit', 'core', 'executionengine', 'scalaropts', 'transformutils', 'instcombine', 'inteljitevents']
 llvm_optional_modules = ['coroutines']
 if with_amd_vk or with_gallium_radeonsi
   llvm_modules += ['amdgpu', 'bitreader', 'ipo']
-- 
2.51.0

